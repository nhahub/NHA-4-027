@model ManageUserRolesViewModel
@{
    ViewData["Title"] = "Manage User Roles";
}

<h1>@ViewData["Title"]</h1>
<h3>User: @Model.UserName</h3>
<form asp-action="ManageRoles" method="post">
    <input type="hidden" asp-for="UserId" />

    <div class="row">
        @for (int i = 0; i < Model.Roles.Count; i++)
        {
            <div class="col-md-4">
                <div class="form-check">
                    <input type="hidden" asp-for="@Model.Roles[i].RoleId" />
                    <input type="hidden" asp-for="@Model.Roles[i].RoleName" />
                    <input asp-for="@Model.Roles[i].IsSelected" class="form-check-input" />
                    <label asp-for="@Model.Roles[i].IsSelected" class="form-check-label">
                        @Model.Roles[i].RoleName
                    </label>
                </div>
            </div>
        }
    </div>

    <div class="mt-3">
        <button type="submit" class="btn btn-primary">Save Changes</button>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </div>
</form>
