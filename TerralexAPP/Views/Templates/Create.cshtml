@model TerralexApp.Models.Template
@{
    Layout = "_DashboardLayout";
}

<div class="mb-4">
    <a asp-action="Index" class="btn btn-premium btn-premium-secondary">
        <i class="bi bi-arrow-left"></i> Back to Templates
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="form-card">
            <h3 class="mb-4 text-primary"><i class="bi bi-file-earmark-arrow-up-fill me-2"></i>New Template</h3>
            
            <form asp-action="Create" method="post" enctype="multipart/form-data" class="row g-3">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="col-12">
                    <label asp-for="TemplateName" class="form-label-premium">Template Name</label>
                    <input asp-for="TemplateName" class="form-control form-control-premium" placeholder="e.g. Sales Contract, Lease Agreement" />
                    <span asp-validation-for="TemplateName" class="text-danger small"></span>
                </div>

                <div class="col-12">
                    <label class="form-label-premium">Template Document File (.docx, .doc, .pdf, .txt)</label>
                    <div class="upload-dropzone" onclick="$('#templateFileInput').click();">
                        <i class="bi bi-cloud-upload text-muted" style="font-size: 2.5rem; display: block; margin-bottom: 0.5rem;"></i>
                        <span class="text-dark fw-medium" id="uploadFilename">Click here to choose file</span>
                    </div>
                    <input type="file" name="templateFile" id="templateFileInput" style="display: none;" onchange="updateFilename(this);" required />
                </div>

                <div class="col-12 mt-4 d-flex justify-content-end gap-2">
                    <button type="reset" class="btn btn-premium btn-premium-secondary" onclick="$('#uploadFilename').text('Click here to choose file');">Reset</button>
                    <button type="submit" class="btn btn-premium btn-premium-primary">
                        <i class="bi bi-check-circle-fill"></i> Upload Template
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        function updateFilename(input) {
            var file = input.files[0];
            if (file) {
                $('#uploadFilename').text(file.name + " (" + (file.size / 1024).toFixed(1) + " KB)");
            } else {
                $('#uploadFilename').text("Click here to choose file");
            }
        }
    </script>
}
